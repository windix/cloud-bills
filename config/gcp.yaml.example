# GCP billing account configuration
# Copy this file to config/gcp.yaml and fill in your values.
# config/gcp.yaml is gitignored — never commit real credentials.

# Name of the account to use when no account is specified in the API path.
default: main

# Option 1: reference a key file on disk (path relative to repo root).
main:
  key_file: ./config/keys/main-billing-sa.json
  project_id: my-gcp-project
  # BigQuery dataset name where billing export lives.
  dataset: billing_export
  # Your GCP billing account ID (format: XXXXXX-XXXXXX-XXXXXX).
  billing_account_id: "AAAAAA-BBBBBB-CCCCCC"

# Option 2: embed the service account JSON directly (project_id is derived
# from the key, so you don't need to repeat it here).
# main:
#   key_json: |
#     {
#       "type": "service_account",
#       "project_id": "my-gcp-project",
#       "private_key_id": "...",
#       "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
#       "client_email": "billing-reader@my-gcp-project.iam.gserviceaccount.com",
#       ...
#     }
#   dataset: billing_export
#   billing_account_id: "AAAAAA-BBBBBB-CCCCCC"

# Add more accounts by repeating the block with a different name.
# secondary:
#   key_file: ./config/keys/secondary-billing-sa.json
#   project_id: another-gcp-project
#   dataset: billing_export
#   billing_account_id: "DDDDDD-EEEEEE-FFFFFF"
